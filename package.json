{
  "name": "codex-bedrock",
  "version": "0.1.0",
  "description": "Use Codex CLI with AWS Bedrock + SSO — zero OpenAI account required",
  "keywords": ["codex", "aws", "bedrock", "claude", "anthropic", "sso", "ai", "cli"],
  "homepage": "https://github.com/apuya-afk/codex-bedrock",
  "repository": {
    "type": "git",
    "url": "https://github.com/apuya-afk/codex-bedrock.git"
  },
  "license": "MIT",
  "bin": {
    "codex-bedrock": "./dist/index.js"
  },
  "files": [
    "dist",
    "proxy"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run build"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "inquirer": "^9.0.0",
    "chalk": "^5.0.0",
    "ora": "^8.0.0",
    "execa": "^9.0.0",
    "find-up": "^7.0.0",
    "@iarna/toml": "^2.2.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
